{
  "name": "nts-desktop-sync",
  "version": "1.1.65",
  "description": "NTS Desktop Sync - Tanzania Tours Desktop Application",
  "author": "Tanzania Tours",
  "private": true,
  "type": "module",
  "main": "./dist/main/electron-main.js",
  "scripts": {
    "dev": "npm-run-all -p dev:renderer dev:main",
    "dev:renderer": "vite --config ./vite.config.ts",
    "dev:main": "wait-on http://localhost:5174 && npm run build:main && electron .",
    "build:renderer": "vite build --config ./vite.config.ts",
    "build:main": "node scripts/build-main.mjs",
    "build": "node scripts/clean-dist.mjs && npm run build:renderer && npm run build:main && electron-builder",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-build.ps1"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.23",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.17",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.27.0",
    "@azure/msal-react": "^3.0.23",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.7.3",
    "embla-carousel-react": "^8.6.0",
    "fast-xml-parser": "^5.3.2",
    "file-saver": "^2.0.5",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "pako": "^2.1.0",
    "pizzip": "^3.2.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "1.0.7",
    "zustand": "^5.0.9"
  }
}


